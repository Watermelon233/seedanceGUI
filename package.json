{
  "name": "seedance-2.0-web",
  "version": "1.0.0",
  "private": true,
  "type": "module",
  "scripts": {
    "dev": "concurrently -n client,server -c cyan,yellow \"npm run dev:client\" \"npm run dev:server\"",
    "dev:client": "vite --host 0.0.0.0 --port 5173",
    "dev:server": "node server/index.js",
    "dev:simple": "node server/simplified-index.js",
    "dev:client-simple": "vite --host 0.0.0.0 --port 5173",
    "dev:all": "concurrently -n client,server -c cyan,yellow \"npm run dev:client-simple\" \"npm run dev:simple\"",
    "build": "tsc && vite build",
    "preview": "vite preview",
    "start": "NODE_ENV=production node server/index.js",
    "start:simple": "NODE_ENV=production node server/simplified-index.js",
    "install:all": "npm install && cd server && npm install"
  },
  "dependencies": {
    "better-sqlite3": "^12.8.0",
    "cors": "^2.8.6",
    "dotenv": "^17.4.1",
    "express": "^5.2.1",
    "multer": "^2.1.1",
    "node-fetch": "^3.3.2",
    "nodemailer": "^8.0.4",
    "playwright-core": "^1.59.1",
    "react": "^19.0.0",
    "react-dom": "^19.0.0",
    "react-router-dom": "^6.22.0"
  },
  "devDependencies": {
    "@types/react": "^19.0.0",
    "@types/react-dom": "^19.0.0",
    "@vitejs/plugin-react": "^4.3.0",
    "autoprefixer": "^10.4.20",
    "concurrently": "^9.0.0",
    "postcss": "^8.4.47",
    "tailwindcss": "^3.4.0",
    "typescript": "^5.6.0",
    "vite": "^6.0.0"
  }
}
